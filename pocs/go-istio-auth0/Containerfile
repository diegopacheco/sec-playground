FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/book-service ./cmd/server

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/book-service /book-service
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/book-service"]
